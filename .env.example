# --- Anthropic (Claude) ---
# Used by @ai-sdk/anthropic. The SDK reads this variable automatically.
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Supabase ---
# Project URL and anon (public) key — safe to expose to the browser.
# Found under Project Settings -> API in the Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service role key — server-side only, NEVER expose to the browser.
# Bypasses Row Level Security. Keep this secret.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
